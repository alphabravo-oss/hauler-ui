# Wagon Environment Configuration
# Copy to .env and adjust. This lists every environment variable Wagon reads.
# The HAULER_UI_* prefix is retained for compatibility with existing deployments.

# ---------------------------------------------------------------------------
# Server & auth
# ---------------------------------------------------------------------------
PORT=8080                      # HTTP UI/API server port
HAULER_UI_PASSWORD=            # optional shared password for UI login; empty disables auth
HAULER_UI_LOGIN_RATE=5         # max login attempts per minute per client IP (429 beyond)
HAULER_UI_TRUST_PROXY=false    # trust rightmost X-Forwarded-For hop for rate-limit IP keying; only enable behind a trusted reverse proxy

# ---------------------------------------------------------------------------
# Published registry / files  (the multi-haul front door)
# ---------------------------------------------------------------------------
HAULER_UI_REGISTRY_PORT=5000   # single host-routed port serving all published haul registries
HAULER_UI_REGISTRY_DOMAIN=     # base domain for <slug>.<domain> registry routing
HAULER_UI_REGISTRY_IDLE=5m     # idle timeout before a published registry subprocess is reaped (Go duration)
HAULER_UI_REGISTRY_TLS_CERT=   # path to a TLS cert for the registry port (self-signed if unset)
HAULER_UI_REGISTRY_TLS_KEY=    # path to the TLS key (self-signed if unset)

# Basic auth guarding the published registry AND the /h/ file endpoints.
# If BOTH user and password are left empty the endpoints are OPEN and a startup WARNING is logged.
HAULER_UI_PUBLISH_USER=        # HTTP Basic auth username
HAULER_UI_PUBLISH_PASSWORD=    # HTTP Basic auth password

# ---------------------------------------------------------------------------
# Jobs & logging  (observability)
# ---------------------------------------------------------------------------
HAULER_UI_MAX_CONCURRENT_JOBS=2 # max background jobs run at once
HAULER_UI_LOG_FORMAT=json       # UI server log format: json or text
HAULER_UI_LOG_LEVEL=info        # UI server log level: debug | info | warn | error

# ---------------------------------------------------------------------------
# Hauler CLI & paths
# ---------------------------------------------------------------------------
HAULER_BINARY=hauler           # hauler binary name/path
HAULER_LOG_LEVEL=info          # Hauler CLI log level
HAULER_IGNORE_ERRORS=false     # continue past non-fatal hauler errors
HAULER_RETRIES=0               # retries for hauler ops (also settable in the Settings UI)

# Data directories (usually left at defaults for containerized deployment)
HAULER_DIR=/data               # base hauler working directory
HAULER_STORE_DIR=/data/store   # hauler content store directory
HAULER_TEMP_DIR=/data/tmp      # hauler temp/scratch directory

DOCKER_CONFIG=/data/.docker    # docker config dir for registry credentials
DATABASE_PATH=/data/app.db     # SQLite database file path
